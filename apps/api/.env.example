# Backend
BUN_ENV=production
PORT=3000

# Database Configuration (Turso)
# Get these from: turso db show <db-name> --url / turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Fallback for local development if Turso is not configured
# DATABASE_URL=file:local.db

# AI Service Configuration
AI_API_BASE=https://api.qnaigc.com/v1
AI_API_KEY=your_api_key_here
AI_API_MODEL=z-ai/glm-5
